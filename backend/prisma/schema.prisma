// ─────────────────────────────────────────────────────────────────────────────
// CSharpTek Payroll System — Prisma Schema
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_NOTICE
  SEPARATED
}

enum UserRole {
  SUPER_ADMIN
  HR
  MANAGEMENT
  EMPLOYEE
}

enum PayrollStatus {
  DRAFT
  CALCULATED
  LOCKED
  DISBURSED
}

enum PayrollEntryStatus {
  PENDING
  CALCULATED
  ADJUSTED
  LOCKED
}

enum PayslipStatus {
  PENDING
  GENERATED
  EMAILED
  FAILED
}

enum FnfStatus {
  INITIATED
  CALCULATED
  APPROVED
  SETTLED
}

enum LoanStatus {
  ACTIVE
  CLOSED
  WRITTEN_OFF
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PAYROLL_RUN
  PAYROLL_LOCK
  PAYROLL_UNLOCK
  PAYSLIP_GENERATE
  FNF_APPROVE
  LOAN_CREATE
  LOAN_CLOSE
  SYNC_TRIGGER
}

enum SyncType {
  FULL
  DELTA
  MANUAL
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── COMPANY ─────────────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(cuid())
  name      String   @default("CSharpTek")
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]
}

// ─── EMPLOYEES ────────────────────────────────────────────────────────────────

model Employee {
  id             String         @id @default(cuid())
  companyId      String
  company        Company        @relation(fields: [companyId], references: [id])

  // Synced from Entra ID — read-only in app
  entraId        String?        @unique
  employeeCode   String         @unique
  name           String
  email          String         @unique
  jobTitle       String?
  department     String?
  mobilePhone    String?
  officeLocation String?

  // Payroll-specific — managed by HR
  state          String?        // For PT slab lookup
  joiningDate    DateTime
  resignationDate DateTime?
  lastWorkingDay  DateTime?
  status         EmployeeStatus @default(ACTIVE)
  role           UserRole       @default(EMPLOYEE)

  // Salary (current — history tracked in SalaryRevision)
  annualCtc      Decimal        @db.Decimal(12, 2)
  annualIncentive Decimal       @default(0) @db.Decimal(12, 2)

  // Compliance
  panNumber      String?
  aadhaarNumber  String?
  pfNumber       String?
  esiNumber      String?
  uanNumber      String?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  bankDetail          BankDetail?
  salaryRevisions     SalaryRevision[]
  payrollEntries      PayrollEntry[]
  lopEntries          LopEntry[]
  reimbursements      Reimbursement[]
  payslips            Payslip[]
  fnfSettlement       FnfSettlement?
  loans               Loan[]
  auditLogs           AuditLog[]       @relation("AuditEmployee")
  performedAudits     AuditLog[]       @relation("AuditPerformer")

  @@index([status])
  @@index([department])
  @@index([entraId])
}

// ─── BANK DETAILS ─────────────────────────────────────────────────────────────

model BankDetail {
  id             String   @id @default(cuid())
  employeeId     String   @unique
  employee       Employee @relation(fields: [employeeId], references: [id])

  accountNumber  String
  ifscCode       String
  bankName       String
  accountName    String

  // Change approval gate — HR must approve before next payroll
  pendingChange  Boolean  @default(false)
  pendingData    Json?    // Stores the proposed new bank details
  approvedAt     DateTime?
  approvedBy     String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── SALARY REVISIONS ────────────────────────────────────────────────────────

model SalaryRevision {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])

  effectiveFrom   DateTime
  previousCtc     Decimal  @db.Decimal(12, 2)
  newCtc          Decimal  @db.Decimal(12, 2)
  previousIncentive Decimal @default(0) @db.Decimal(12, 2)
  newIncentive    Decimal  @default(0) @db.Decimal(12, 2)
  reason          String?
  revisedBy       String   // Employee ID of HR who made the change
  revisedByName   String

  createdAt       DateTime @default(now())

  @@index([employeeId])
  @@index([effectiveFrom])
}

// ─── PAYROLL CYCLES ──────────────────────────────────────────────────────────

model PayrollCycle {
  id            String        @id @default(cuid())
  cycleStart    DateTime      // 26th of previous month
  cycleEnd      DateTime      // 25th of current month
  payrollMonth  String        // e.g. "2025-04" — display label
  payrollDate   DateTime      // 27th — when calculation runs
  payslipDate   DateTime      // 5th of next month — when payslips release
  salaryDate    DateTime      // Last day of month — when salary is paid

  status        PayrollStatus @default(DRAFT)
  lockedAt      DateTime?
  lockedBy      String?
  unlockedAt    DateTime?
  unlockedBy    String?
  unlockReason  String?
  disbursedAt   DateTime?
  disbursedBy   String?

  runAt         DateTime?     // When payroll engine was last run
  runBy         String?

  totalGross    Decimal?      @db.Decimal(14, 2)
  totalNet      Decimal?      @db.Decimal(14, 2)
  totalPf       Decimal?      @db.Decimal(14, 2)
  totalEsi      Decimal?      @db.Decimal(14, 2)
  employeeCount Int?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  entries       PayrollEntry[]
  lopEntries    LopEntry[]
  reimbursements Reimbursement[]
  payslips      Payslip[]

  @@index([payrollMonth])
  @@index([status])
}

// ─── PAYROLL ENTRIES ─────────────────────────────────────────────────────────

model PayrollEntry {
  id              String             @id @default(cuid())
  cycleId         String
  cycle           PayrollCycle       @relation(fields: [cycleId], references: [id])
  employeeId      String
  employee        Employee           @relation(fields: [employeeId], references: [id])

  // Salary structure snapshot at time of calculation
  annualCtc       Decimal            @db.Decimal(12, 2)
  monthlyCtc      Decimal            @db.Decimal(12, 2)
  basic           Decimal            @db.Decimal(12, 2)
  hra             Decimal            @db.Decimal(12, 2)
  allowances      Decimal            @db.Decimal(12, 2)
  grossSalary     Decimal            @db.Decimal(12, 2)

  // Proration
  totalDays       Int
  payableDays     Int
  isProrated      Boolean            @default(false)
  proratedGross   Decimal            @db.Decimal(12, 2)

  // Additions
  incentive       Decimal            @default(0) @db.Decimal(12, 2)
  reimbursementTotal Decimal         @default(0) @db.Decimal(12, 2)

  // Deductions
  lopDays         Int                @default(0)
  lopAmount       Decimal            @default(0) @db.Decimal(12, 2)
  pfAmount        Decimal            @default(0) @db.Decimal(12, 2)
  esiAmount       Decimal            @default(0) @db.Decimal(12, 2)
  ptAmount        Decimal            @default(0) @db.Decimal(12, 2)
  tdsAmount       Decimal            @default(0) @db.Decimal(12, 2)
  incentiveRecovery Decimal          @default(0) @db.Decimal(12, 2)
  loanDeduction   Decimal            @default(0) @db.Decimal(12, 2)

  // Net
  netSalary       Decimal            @db.Decimal(12, 2)

  // Adjustment note (if HR manually overrides)
  adjustmentNote  String?
  adjustedBy      String?

  status          PayrollEntryStatus @default(PENDING)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  payslip         Payslip?
  loanRepayments  LoanRepayment[]

  @@unique([cycleId, employeeId])
  @@index([cycleId])
  @@index([employeeId])
}

// ─── LOP ENTRIES ─────────────────────────────────────────────────────────────

model LopEntry {
  id          String       @id @default(cuid())
  cycleId     String
  cycle       PayrollCycle @relation(fields: [cycleId], references: [id])
  employeeId  String
  employee    Employee     @relation(fields: [employeeId], references: [id])

  lopDays     Int
  reason      String?
  approvedBy  String?
  approvedByName String?
  approvedAt  DateTime?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([cycleId, employeeId])
}

// ─── REIMBURSEMENTS ──────────────────────────────────────────────────────────

model Reimbursement {
  id          String       @id @default(cuid())
  cycleId     String
  cycle       PayrollCycle @relation(fields: [cycleId], references: [id])
  employeeId  String
  employee    Employee     @relation(fields: [employeeId], references: [id])

  category    String       // e.g. Travel, Medical, Internet
  amount      Decimal      @db.Decimal(10, 2)
  notes       String?
  addedBy     String
  addedByName String

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// ─── PAYSLIPS ────────────────────────────────────────────────────────────────

model Payslip {
  id            String        @id @default(cuid())
  cycleId       String
  cycle         PayrollCycle  @relation(fields: [cycleId], references: [id])
  employeeId    String
  employee      Employee      @relation(fields: [employeeId], references: [id])
  entryId       String        @unique
  entry         PayrollEntry  @relation(fields: [entryId], references: [id])

  pdfUrl        String?       // Cloudflare R2 URL
  pdfKey        String?       // R2 object key
  status        PayslipStatus @default(PENDING)

  generatedAt   DateTime?
  emailedAt     DateTime?
  emailStatus   String?       // delivered / bounced / etc

  // Re-generation tracking
  version       Int           @default(1)
  regeneratedAt DateTime?
  regeneratedBy String?
  regenerationReason String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([cycleId])
  @@index([employeeId])
}

// ─── FULL & FINAL SETTLEMENT ─────────────────────────────────────────────────

model FnfSettlement {
  id                  String      @id @default(cuid())
  employeeId          String      @unique
  employee            Employee    @relation(fields: [employeeId], references: [id])

  resignationDate     DateTime
  lastWorkingDay      DateTime
  noticePeriosDays    Int         @default(0)

  // Salary component
  salaryDays          Int
  salaryAmount        Decimal     @db.Decimal(12, 2)

  // Additions
  reimbursements      Decimal     @default(0) @db.Decimal(12, 2)

  // Deductions
  pfAmount            Decimal     @default(0) @db.Decimal(12, 2)
  esiAmount           Decimal     @default(0) @db.Decimal(12, 2)
  ptAmount            Decimal     @default(0) @db.Decimal(12, 2)
  tdsAmount           Decimal     @default(0) @db.Decimal(12, 2)
  incentiveRecovery   Decimal     @default(0) @db.Decimal(12, 2)
  loanOutstanding     Decimal     @default(0) @db.Decimal(12, 2)
  otherDeductions     Decimal     @default(0) @db.Decimal(12, 2)

  netPayable          Decimal     @db.Decimal(12, 2)

  status              FnfStatus   @default(INITIATED)
  approvedBy          String?
  approvedByName      String?
  approvedAt          DateTime?

  pdfUrl              String?
  pdfKey              String?

  notes               String?

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

// ─── LOANS & ADVANCES ────────────────────────────────────────────────────────

model Loan {
  id              String          @id @default(cuid())
  employeeId      String
  employee        Employee        @relation(fields: [employeeId], references: [id])

  principalAmount Decimal         @db.Decimal(12, 2)
  disbursedOn     DateTime
  tenureMonths    Int
  emiAmount       Decimal         @db.Decimal(10, 2)
  interestRate    Decimal         @default(0) @db.Decimal(5, 2) // 0 for interest-free
  purpose         String?

  totalRepaid     Decimal         @default(0) @db.Decimal(12, 2)
  outstandingBalance Decimal      @db.Decimal(12, 2)

  status          LoanStatus      @default(ACTIVE)
  closedAt        DateTime?
  closedBy        String?
  closureNote     String?

  approvedBy      String
  approvedByName  String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  repayments      LoanRepayment[]

  @@index([employeeId])
  @@index([status])
}

model LoanRepayment {
  id          String       @id @default(cuid())
  loanId      String
  loan        Loan         @relation(fields: [loanId], references: [id])
  entryId     String
  entry       PayrollEntry @relation(fields: [entryId], references: [id])

  amount      Decimal      @db.Decimal(10, 2)
  cycleMonth  String       // e.g. "2025-04"
  paidOn      DateTime

  createdAt   DateTime     @default(now())
}

// ─── PT SLABS ────────────────────────────────────────────────────────────────

model PtSlab {
  id            String   @id @default(cuid())
  state         String
  minSalary     Decimal  @db.Decimal(10, 2)
  maxSalary     Decimal? @db.Decimal(10, 2) // null = no upper limit
  ptAmount      Decimal  @db.Decimal(8, 2)
  effectiveFrom DateTime @default(now())

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([state])
}

// ─── SYSTEM CONFIGURATION ────────────────────────────────────────────────────

model SystemConfig {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

// ─── AUDIT LOG ───────────────────────────────────────────────────────────────

model AuditLog {
  id            String      @id @default(cuid())

  // Who did it
  performedById String
  performedBy   Employee    @relation("AuditPerformer", fields: [performedById], references: [id])
  performedByName String
  performedByRole UserRole

  // What they did
  action        AuditAction
  tableName     String?     // e.g. "employees", "payroll_entries"
  recordId      String?     // ID of the affected record

  // On whom (optional — for employee-specific actions)
  targetEmployeeId String?
  targetEmployee   Employee? @relation("AuditEmployee", fields: [targetEmployeeId], references: [id])

  // The change
  previousValue Json?       // Before state
  newValue      Json?       // After state
  description   String?     // Human-readable summary

  ipAddress     String?
  userAgent     String?

  createdAt     DateTime    @default(now())

  @@index([performedById])
  @@index([action])
  @@index([tableName])
  @@index([targetEmployeeId])
  @@index([createdAt])
}

// ─── GRAPH API SYNC LOG ──────────────────────────────────────────────────────

model SyncLog {
  id                  String     @id @default(cuid())
  syncType            SyncType
  triggeredBy         String?    // Employee ID if manual, null if cron
  triggeredByName     String?

  status              String     // success / failed / partial
  recordsAdded        Int        @default(0)
  recordsUpdated      Int        @default(0)
  recordsDeactivated  Int        @default(0)
  recordsSkipped      Int        @default(0)

  deltaToken          String?    // Stored for next delta sync
  errorMessage        String?
  errorDetails        Json?

  startedAt           DateTime   @default(now())
  completedAt         DateTime?

  @@index([syncType])
  @@index([startedAt])
}

// ─── BULK IMPORT ─────────────────────────────────────────────────────────────

model BulkImport {
  id            String       @id @default(cuid())
  importedBy    String
  importedByName String
  fileName      String
  totalRows     Int
  successRows   Int          @default(0)
  failedRows    Int          @default(0)
  status        ImportStatus @default(PENDING)
  errors        Json?        // Array of {row, field, message}
  createdAt     DateTime     @default(now())
  completedAt   DateTime?
}

// ─── FUTURE: LEAVE MODULE (TABLES READY) ────────────────────────────────────
// These tables are stubbed out now so the leave module can be added
// without any schema rework later.

model LeaveType {
  id            String        @id @default(cuid())
  name          String        // Casual, Sick, Earned, etc.
  annualQuota   Int           // Days per year
  carryForward  Boolean       @default(false)
  maxCarryDays  Int           @default(0)
  isPaid        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  balances      LeaveBalance[]
  applications  LeaveApplication[]
}

model LeaveBalance {
  id            String    @id @default(cuid())
  employeeId    String
  leaveTypeId   String
  leaveType     LeaveType @relation(fields: [leaveTypeId], references: [id])
  year          Int
  totalDays     Decimal   @db.Decimal(5, 2) // Prorated for mid-year joiners
  usedDays      Decimal   @default(0) @db.Decimal(5, 2)
  pendingDays   Decimal   @default(0) @db.Decimal(5, 2)
  balanceDays   Decimal   @db.Decimal(5, 2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([employeeId, leaveTypeId, year])
}

model LeaveApplication {
  id            String    @id @default(cuid())
  employeeId    String
  leaveTypeId   String
  leaveType     LeaveType @relation(fields: [leaveTypeId], references: [id])
  fromDate      DateTime
  toDate        DateTime
  totalDays     Decimal   @db.Decimal(5, 2)
  reason        String?
  status        String    @default("PENDING") // PENDING / APPROVED / REJECTED / CANCELLED
  approvedBy    String?
  approvedAt    DateTime?
  rejectionNote String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
