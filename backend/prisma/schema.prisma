// ─────────────────────────────────────────────────────────────────────────────
// CSharpTek Payroll System — Prisma Schema v2
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_NOTICE
  SEPARATED
}

enum ExitType {
  RESIGNED
  TERMINATED
  ABSCONDED
}

enum UserRole {
  SUPER_ADMIN
  HR
  MANAGEMENT
  EMPLOYEE
}

enum PayrollStatus {
  DRAFT
  CALCULATED
  LOCKED
  DISBURSED
}

enum PayrollEntryStatus {
  PENDING
  CALCULATED
  ADJUSTED
  LOCKED
}

enum PayslipStatus {
  PENDING
  GENERATED
  EMAILED
  FAILED
}

enum FnfStatus {
  INITIATED
  CALCULATED
  APPROVED
  SETTLED
}

enum LoanStatus {
  ACTIVE
  CLOSED
  WRITTEN_OFF
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PAYROLL_RUN
  PAYROLL_LOCK
  PAYROLL_UNLOCK
  PAYSLIP_GENERATE
  FNF_APPROVE
  LOAN_CREATE
  LOAN_CLOSE
  SYNC_TRIGGER
  SALARY_REVISION
}

enum SyncType {
  FULL
  DELTA
  MANUAL
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── COMPANY ─────────────────────────────────────────────────────────────────

model Company {
  id        String   @id @default(cuid())
  name      String   @default("CSharpTek")
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]
}

// ─── EMPLOYEES ────────────────────────────────────────────────────────────────

model Employee {
  id             String         @id @default(cuid())
  companyId      String
  company        Company        @relation(fields: [companyId], references: [id])

  // Synced from Entra ID
  entraId        String?        @unique
  employeeCode   String         @unique
  name           String
  email          String         @unique
  jobTitle       String?
  department     String?
  mobilePhone    String?
  officeLocation String?

  // Payroll-specific
  state          String?
  joiningDate    DateTime
  resignationDate DateTime?
  lastWorkingDay  DateTime?
  status         EmployeeStatus @default(ACTIVE)
  role           UserRole       @default(EMPLOYEE)

  // Exit / Resignation
  exitType                ExitType?
  resignationSubmittedAt  DateTime?
  resignationReason       String?   @db.Text
  resignationRequests     String?   @db.Text
  resignationInitiatedBy  String?
  resignationInitiatorId  String?
  withdrawalEnabled       Boolean   @default(false)
  withdrawnAt             DateTime?
  noticePeriodDays        Int?
  expectedLwd             DateTime?
  noticePeriodServed      Boolean   @default(false)
  buyoutAmount            Decimal?  @db.Decimal(10, 2)

  // ─── NEW SALARY STRUCTURE (v2) ───────────────────────────────────────────
  annualCtc           Decimal  @db.Decimal(12, 2)

  // Salary component percentages (stored so HR can override per employee)
  basicPercent        Decimal  @default(45) @db.Decimal(5, 2)   // default 45% of CTC
  hraPercent          Decimal  @default(35) @db.Decimal(5, 2)   // default 35% of CTC

  // Fixed monthly allowances (HR editable, default = 4% of Basic monthly)
  transportMonthly    Decimal? @db.Decimal(10, 2)  // null = use default formula
  fbpMonthly          Decimal? @db.Decimal(10, 2)  // null = use default formula

  // Mediclaim (annual, optional)
  mediclaim           Decimal  @default(0) @db.Decimal(10, 2)

  // Incentive / Annual Bonus
  hasIncentive        Boolean  @default(false)
  incentivePercent    Decimal  @default(12) @db.Decimal(5, 2)   // % of CTC
  // Annual/Joining bonus = CTC × incentivePercent (paid in March every year)
  // Computed field — not stored, calculated from above

  // TDS (manual per employee)
  tdsMonthly          Decimal  @default(0) @db.Decimal(10, 2)

  // Compliance
  panNumber      String?
  aadhaarNumber  String?
  pfNumber       String?
  esiNumber      String?
  uanNumber      String?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  bankDetail          BankDetail?
  salaryRevisions     SalaryRevision[]
  payrollEntries      PayrollEntry[]
  lopEntries          LopEntry[]
  reimbursements      Reimbursement[]
  payslips            Payslip[]
  fnfSettlement       FnfSettlement?
  loans               Loan[]
  auditLogs           AuditLog[]       @relation("AuditEmployee")
  performedAudits     AuditLog[]       @relation("AuditPerformer")

  // Extended profile relations
  profile             EmployeeProfile?
  address             EmployeeAddress?
  emergencyContacts   EmergencyContact[]
  educationRecords    EducationRecord[]
  workExperiences     WorkExperience[]
  employmentDetail    EmploymentDetail?
  bankAccounts        BankAccount[]
  documents           EmployeeDocument[]
  governmentId        GovernmentId?

  // Leave module relations (new — no change to existing fields)
  leaveEntitlements   LeaveEntitlement[]     @relation("EmployeeLeaveEntitlements")
  leaveApplications   LvApplication[]        @relation("EmployeeLeaveApplications")
  leaveSnapshots      LeaveBalanceSnapshot[] @relation("EmployeeLeaveSnapshots")
  exitClearance       ExitClearance?
  exitInterview       ExitInterview?
  resignationHistory  ResignationHistory[]

  @@index([status])
  @@index([department])
  @@index([entraId])
}

// ─── BANK DETAILS ─────────────────────────────────────────────────────────────

model BankDetail {
  id             String   @id @default(cuid())
  employeeId     String   @unique
  employee       Employee @relation(fields: [employeeId], references: [id])

  accountNumber  String
  ifscCode       String
  bankName       String
  accountName    String

  pendingChange  Boolean  @default(false)
  pendingData    Json?
  approvedAt     DateTime?
  approvedBy     String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── SALARY REVISIONS ────────────────────────────────────────────────────────

model SalaryRevision {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])

  effectiveFrom   DateTime

  // Full salary snapshot at time of revision
  previousCtc          Decimal  @db.Decimal(12, 2)
  newCtc               Decimal  @db.Decimal(12, 2)
  previousBasicPct     Decimal  @default(45) @db.Decimal(5, 2)
  newBasicPct          Decimal  @default(45) @db.Decimal(5, 2)
  previousHraPct       Decimal  @default(35) @db.Decimal(5, 2)
  newHraPct            Decimal  @default(35) @db.Decimal(5, 2)
  previousHasIncentive Boolean  @default(false)
  newHasIncentive      Boolean  @default(false)
  previousIncentivePct Decimal  @default(12) @db.Decimal(5, 2)
  newIncentivePct      Decimal  @default(12) @db.Decimal(5, 2)
  previousTransport    Decimal? @db.Decimal(10, 2)
  newTransport         Decimal? @db.Decimal(10, 2)
  previousFbp          Decimal? @db.Decimal(10, 2)
  newFbp               Decimal? @db.Decimal(10, 2)
  previousMediclaim    Decimal  @default(0) @db.Decimal(10, 2)
  newMediclaim         Decimal  @default(0) @db.Decimal(10, 2)
  previousTds          Decimal  @default(0) @db.Decimal(10, 2)
  newTds               Decimal  @default(0) @db.Decimal(10, 2)

  reason          String?
  revisedBy       String
  revisedByName   String

  createdAt       DateTime @default(now())

  @@index([employeeId])
  @@index([effectiveFrom])
}

// ─── PAYROLL CYCLES ──────────────────────────────────────────────────────────

model PayrollCycle {
  id            String        @id @default(cuid())
  cycleStart    DateTime
  cycleEnd      DateTime
  payrollMonth  String
  payrollDate   DateTime
  payslipDate   DateTime
  salaryDate    DateTime

  status        PayrollStatus @default(DRAFT)
  lockedAt      DateTime?
  lockedBy      String?
  unlockedAt    DateTime?
  unlockedBy    String?
  unlockReason  String?
  disbursedAt   DateTime?
  disbursedBy   String?
  runAt         DateTime?
  runBy         String?

  totalGross    Decimal?      @db.Decimal(14, 2)
  totalNet      Decimal?      @db.Decimal(14, 2)
  totalPf       Decimal?      @db.Decimal(14, 2)
  totalEsi      Decimal?      @db.Decimal(14, 2)
  employeeCount Int?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  entries        PayrollEntry[]
  lopEntries     LopEntry[]
  reimbursements Reimbursement[]
  payslips       Payslip[]

  @@index([payrollMonth])
  @@index([status])
}

// ─── PAYROLL ENTRIES ─────────────────────────────────────────────────────────

model PayrollEntry {
  id              String             @id @default(cuid())
  cycleId         String
  cycle           PayrollCycle       @relation(fields: [cycleId], references: [id])
  employeeId      String
  employee        Employee           @relation(fields: [employeeId], references: [id])

  // Salary snapshot
  annualCtc       Decimal            @db.Decimal(12, 2)
  monthlyCtc      Decimal            @db.Decimal(12, 2)
  basic           Decimal            @db.Decimal(12, 2)
  hra             Decimal            @db.Decimal(12, 2)
  transport       Decimal            @default(0) @db.Decimal(10, 2)
  fbp             Decimal            @default(0) @db.Decimal(10, 2)
  hyi             Decimal            @default(0) @db.Decimal(10, 2)   // balancing component
  grossSalary     Decimal            @db.Decimal(12, 2)               // grand total
  annualBonus     Decimal            @default(0) @db.Decimal(12, 2)   // March payout
  isBolusMonth    Boolean            @default(false)                  // true in March

  // Proration
  totalDays       Int
  payableDays     Int
  isProrated      Boolean            @default(false)
  proratedGross   Decimal            @db.Decimal(12, 2)

  // Additions
  incentive       Decimal            @default(0) @db.Decimal(12, 2)   // monthly incentive
  reimbursementTotal Decimal         @default(0) @db.Decimal(12, 2)

  // Deductions
  lopDays         Int                @default(0)
  lopAmount       Decimal            @default(0) @db.Decimal(12, 2)
  pfAmount        Decimal            @default(0) @db.Decimal(12, 2)
  esiAmount       Decimal            @default(0) @db.Decimal(12, 2)
  ptAmount        Decimal            @default(0) @db.Decimal(12, 2)
  tdsAmount       Decimal            @default(0) @db.Decimal(12, 2)
  incentiveRecovery Decimal          @default(0) @db.Decimal(12, 2)
  loanDeduction   Decimal            @default(0) @db.Decimal(12, 2)

  netSalary       Decimal            @db.Decimal(12, 2)

  adjustmentNote  String?
  adjustedBy      String?
  status          PayrollEntryStatus @default(PENDING)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  payslip         Payslip?
  loanRepayments  LoanRepayment[]

  @@unique([cycleId, employeeId])
  @@index([cycleId])
  @@index([employeeId])
}

// ─── LOP ENTRIES ─────────────────────────────────────────────────────────────

model LopEntry {
  id          String       @id @default(cuid())
  cycleId     String
  cycle       PayrollCycle @relation(fields: [cycleId], references: [id])
  employeeId  String
  employee    Employee     @relation(fields: [employeeId], references: [id])

  lopDays     Int
  reason      String?
  approvedBy  String?
  approvedByName String?
  approvedAt  DateTime?

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([cycleId, employeeId])
}

// ─── REIMBURSEMENTS ──────────────────────────────────────────────────────────

model Reimbursement {
  id          String       @id @default(cuid())
  cycleId     String
  cycle       PayrollCycle @relation(fields: [cycleId], references: [id])
  employeeId  String
  employee    Employee     @relation(fields: [employeeId], references: [id])

  category    String
  amount      Decimal      @db.Decimal(10, 2)
  notes       String?
  addedBy     String
  addedByName String

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// ─── PAYSLIPS ────────────────────────────────────────────────────────────────

model Payslip {
  id            String        @id @default(cuid())
  cycleId       String
  cycle         PayrollCycle  @relation(fields: [cycleId], references: [id])
  employeeId    String
  employee      Employee      @relation(fields: [employeeId], references: [id])
  entryId       String        @unique
  entry         PayrollEntry  @relation(fields: [entryId], references: [id])

  pdfUrl        String?
  pdfKey        String?
  status        PayslipStatus @default(PENDING)

  generatedAt   DateTime?
  emailedAt     DateTime?
  emailStatus   String?

  version       Int           @default(1)
  regeneratedAt DateTime?
  regeneratedBy String?
  regenerationReason String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([cycleId])
  @@index([employeeId])
}

// ─── F&F SETTLEMENT ──────────────────────────────────────────────────────────

model FnfSettlement {
  id                  String      @id @default(cuid())
  employeeId          String      @unique
  employee            Employee    @relation(fields: [employeeId], references: [id])

  resignationDate     DateTime
  lastWorkingDay      DateTime
  noticePeriosDays    Int         @default(0)

  salaryDays          Int
  salaryAmount        Decimal     @db.Decimal(12, 2)
  reimbursements      Decimal     @default(0) @db.Decimal(12, 2)

  pfAmount            Decimal     @default(0) @db.Decimal(12, 2)
  esiAmount           Decimal     @default(0) @db.Decimal(12, 2)
  ptAmount            Decimal     @default(0) @db.Decimal(12, 2)
  tdsAmount           Decimal     @default(0) @db.Decimal(12, 2)
  incentiveRecovery   Decimal     @default(0) @db.Decimal(12, 2)
  loanOutstanding     Decimal     @default(0) @db.Decimal(12, 2)
  otherDeductions     Decimal     @default(0) @db.Decimal(12, 2)

  netPayable          Decimal     @db.Decimal(12, 2)

  status              FnfStatus   @default(INITIATED)
  approvedBy          String?
  approvedByName      String?
  approvedAt          DateTime?

  pdfUrl              String?
  pdfKey              String?
  notes               String?

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

// ─── LOANS ───────────────────────────────────────────────────────────────────

model Loan {
  id              String          @id @default(cuid())
  employeeId      String
  employee        Employee        @relation(fields: [employeeId], references: [id])

  principalAmount Decimal         @db.Decimal(12, 2)
  disbursedOn     DateTime
  tenureMonths    Int
  emiAmount       Decimal         @db.Decimal(10, 2)
  interestRate    Decimal         @default(0) @db.Decimal(5, 2)
  purpose         String?

  totalRepaid     Decimal         @default(0) @db.Decimal(12, 2)
  outstandingBalance Decimal      @db.Decimal(12, 2)

  status          LoanStatus      @default(ACTIVE)
  closedAt        DateTime?
  closedBy        String?
  closureNote     String?

  approvedBy      String
  approvedByName  String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  repayments      LoanRepayment[]

  @@index([employeeId])
  @@index([status])
}

model LoanRepayment {
  id          String       @id @default(cuid())
  loanId      String
  loan        Loan         @relation(fields: [loanId], references: [id])
  entryId     String
  entry       PayrollEntry @relation(fields: [entryId], references: [id])

  amount      Decimal      @db.Decimal(10, 2)
  cycleMonth  String
  paidOn      DateTime

  createdAt   DateTime     @default(now())
}

// ─── PT SLABS ────────────────────────────────────────────────────────────────

model PtSlab {
  id            String   @id @default(cuid())
  state         String
  minSalary     Decimal  @db.Decimal(10, 2)
  maxSalary     Decimal? @db.Decimal(10, 2)
  ptAmount      Decimal  @db.Decimal(8, 2)
  effectiveFrom DateTime @default(now())

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([state])
}

// ─── SYSTEM CONFIGURATION ────────────────────────────────────────────────────

model SystemConfig {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

// ─── SYNC DOMAIN CONFIG ──────────────────────────────────────────────────────
// Stores which Entra ID domains are selected for sync

model SyncDomainConfig {
  id        String   @id @default(cuid())
  domain    String   @unique
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── AUDIT LOG ───────────────────────────────────────────────────────────────

model AuditLog {
  id            String      @id @default(cuid())

  performedById   String
  performedBy     Employee    @relation("AuditPerformer", fields: [performedById], references: [id])
  performedByName String
  performedByRole UserRole

  action        AuditAction
  tableName     String?
  recordId      String?

  targetEmployeeId String?
  targetEmployee   Employee? @relation("AuditEmployee", fields: [targetEmployeeId], references: [id])

  previousValue Json?
  newValue      Json?
  description   String?

  ipAddress     String?
  userAgent     String?

  createdAt     DateTime    @default(now())

  @@index([performedById])
  @@index([action])
  @@index([tableName])
  @@index([targetEmployeeId])
  @@index([createdAt])
}

// ─── SYNC LOG ────────────────────────────────────────────────────────────────

model SyncLog {
  id                  String     @id @default(cuid())
  syncType            SyncType
  triggeredBy         String?
  triggeredByName     String?

  status              String
  recordsAdded        Int        @default(0)
  recordsUpdated      Int        @default(0)
  recordsDeactivated  Int        @default(0)
  recordsSkipped      Int        @default(0)

  deltaToken          String?
  errorMessage        String?
  errorDetails        Json?

  startedAt           DateTime   @default(now())
  completedAt         DateTime?

  @@index([syncType])
  @@index([startedAt])
}

// ─── BULK IMPORT ─────────────────────────────────────────────────────────────

model BulkImport {
  id            String       @id @default(cuid())
  importedBy    String
  importedByName String
  fileName      String
  totalRows     Int
  successRows   Int          @default(0)
  failedRows    Int          @default(0)
  status        ImportStatus @default(PENDING)
  errors        Json?
  createdAt     DateTime     @default(now())
  completedAt   DateTime?
}

// ─── LEAVE MODULE (STUBBED) ──────────────────────────────────────────────────

model LeaveType {
  id            String        @id @default(cuid())
  name          String
  annualQuota   Int
  carryForward  Boolean       @default(false)
  maxCarryDays  Int           @default(0)
  isPaid        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  balances      LeaveBalance[]
  applications  LeaveApplication[]
}

model LeaveBalance {
  id            String    @id @default(cuid())
  employeeId    String
  leaveTypeId   String
  leaveType     LeaveType @relation(fields: [leaveTypeId], references: [id])
  year          Int
  totalDays     Decimal   @db.Decimal(5, 2)
  usedDays      Decimal   @default(0) @db.Decimal(5, 2)
  pendingDays   Decimal   @default(0) @db.Decimal(5, 2)
  balanceDays   Decimal   @db.Decimal(5, 2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([employeeId, leaveTypeId, year])
}

model LeaveApplication {
  id            String    @id @default(cuid())
  employeeId    String
  leaveTypeId   String
  leaveType     LeaveType @relation(fields: [leaveTypeId], references: [id])
  fromDate      DateTime
  toDate        DateTime
  totalDays     Decimal   @db.Decimal(5, 2)
  reason        String?
  status        String    @default("PENDING")
  approvedBy    String?
  approvedAt    DateTime?
  rejectionNote String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ─── EMPLOYEE PROFILE (extended personal info) ───────────────────────────────

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

enum BloodGroup {
  A_POS
  A_NEG
  B_POS
  B_NEG
  AB_POS
  AB_NEG
  O_POS
  O_NEG
}

model EmployeeProfile {
  id              String         @id @default(cuid())
  employeeId      String         @unique
  employee        Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  firstName       String?
  lastName        String?
  personalEmail   String?
  dateOfBirth     DateTime?
  gender          Gender?
  maritalStatus   MaritalStatus?
  bloodGroup      BloodGroup?
  profilePhotoUrl String?
  profilePhotoKey String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// ─── ADDRESS ─────────────────────────────────────────────────────────────────

model EmployeeAddress {
  id              String   @id @default(cuid())
  employeeId      String   @unique
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // Current
  currentLine1    String?
  currentLine2    String?
  currentCity     String?
  currentState    String?
  currentPin      String?
  currentCountry  String?  @default("India")

  // Permanent
  sameAsCurrent   Boolean  @default(false)
  permanentLine1  String?
  permanentLine2  String?
  permanentCity   String?
  permanentState  String?
  permanentPin    String?
  permanentCountry String?  @default("India")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── EMERGENCY CONTACTS (multiple) ───────────────────────────────────────────

enum ContactType {
  EMERGENCY
  PARENT
  SPOUSE
  GUARDIAN
  OTHER
}

model EmergencyContact {
  id             String      @id @default(cuid())
  employeeId     String
  employee       Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  name           String
  relationship   String
  contactType    ContactType @default(EMERGENCY)
  phone          String
  alternatePhone String?
  email          String?
  address        String?

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([employeeId])
}

// ─── EDUCATION (multiple) ─────────────────────────────────────────────────────

model EducationRecord {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  degree          String
  institution     String
  specialization  String?
  yearOfPassing   Int?
  percentageGrade String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([employeeId])
}

// ─── WORK EXPERIENCE (multiple) ──────────────────────────────────────────────

model WorkExperience {
  id               String    @id @default(cuid())
  employeeId       String
  employee         Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  companyName      String
  designation      String
  startDate        DateTime
  endDate          DateTime?
  lastDrawnSalary  Decimal?  @db.Decimal(12, 2)
  reasonForLeaving String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([employeeId])
}

// ─── EMPLOYMENT DETAIL (extended, 1:1) ───────────────────────────────────────

enum EmploymentType {
  FULL_TIME
  CONTRACT
  INTERN
  PART_TIME
}

model EmploymentDetail {
  id                String         @id @default(cuid())
  employeeId        String         @unique
  employee          Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  employmentType    EmploymentType @default(FULL_TIME)
  reportingManagerId String?
  workLocation      String?
  probationMonths   Int?           @default(0)

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

// ─── BANK ACCOUNT (multiple, alongside existing BankDetail) ──────────────────

enum AccountType {
  SAVINGS
  CURRENT
}

model BankAccount {
  id                  String      @id @default(cuid())
  employeeId          String
  employee            Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  accountHolderName   String
  accountNumber       String
  ifscCode            String
  bankName            String
  branchName          String?
  accountType         AccountType @default(SAVINGS)
  isPrimary           Boolean     @default(false)
  documentUrl         String?
  documentKey         String?

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([employeeId])
}

// ─── EMPLOYEE DOCUMENTS ───────────────────────────────────────────────────────

enum DocumentType {
  PROFILE_PHOTO
  PAN_CARD
  AADHAAR_CARD
  PASSPORT
  OFFER_LETTER
  RELIEVING_LETTER
  APPOINTMENT_LETTER
  EXPERIENCE_LETTER
  EDUCATION_CERTIFICATE
  ADDRESS_PROOF
  BANK_PROOF
  OTHER
}

model EmployeeDocument {
  id           String       @id @default(cuid())
  employeeId   String
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  documentType DocumentType
  fileName     String
  fileUrl      String
  fileKey      String
  fileSize     Int?
  mimeType     String?
  isVerified      Boolean      @default(false)
  verifiedBy      String?
  verifiedAt      DateTime?
  notes           String?
  referenceNumber String?
  isLocked        Boolean      @default(false)
  uploadedByRole  String?

  uploadedBy   String
  uploadedAt   DateTime     @default(now())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([employeeId])
  @@index([documentType])
}

// ─── GOVERNMENT IDS (extended from existing fields) ──────────────────────────

model GovernmentId {
  id             String   @id @default(cuid())
  employeeId     String   @unique
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  panNumber      String?
  panDocUrl      String?
  aadhaarNumber  String?  // stored masked
  aadhaarDocUrl  String?
  passportNumber String?
  passportExpiry DateTime?
  passportDocUrl String?
  uanNumber      String?
  esicNumber     String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════════════════════
// LEAVE MODULE — all new models, zero changes to existing schema
// Leave FY: January – December (independent of payroll FY Apr–Mar)
// ═══════════════════════════════════════════════════════════════════════════════

enum LeaveKind {
  SICK
  CASUAL
  PLANNED
}

enum LeaveStatus {
  PENDING
  APPROVED
  DECLINED
  CANCELLED
  AUTO_APPROVED
  LOP
}

enum HalfDaySlot {
  FIRST   // 9:00am – 1:30pm
  SECOND  // 1:30pm – 6:00pm
}

enum CancellationStatus {
  PENDING
  APPROVED
  DECLINED
  AUTO_CANCELLED
}

// ─── LEAVE POLICY ─────────────────────────────────────────────────────────────
// One record per company. HR can edit quotas + advance days.
// SUPER_ADMIN only can edit carry forward rules.

model LeavePolicy {
  id                        String   @id @default(cuid())
  companyId                 String   @unique

  // Annual quotas (HR editable)
  sickDaysPerYear           Int      @default(4)
  casualDaysPerYear         Int      @default(8)
  plannedDaysPerYear        Int      @default(8)

  // Advance notice in days (HR editable)
  sickAdvanceDays           Int      @default(0)
  casualAdvanceDays         Int      @default(2)
  plannedAdvanceDays        Int      @default(7)

  // Carry forward rules (SUPER_ADMIN only)
  plannedCarryForwardMax    Int      @default(8)
  plannedBalanceCap         Int      @default(16)

  // Half day slots
  firstHalfStart            String   @default("09:00")
  firstHalfEnd              String   @default("13:30")
  secondHalfStart           String   @default("13:30")
  secondHalfEnd             String   @default("18:00")

  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

// ─── LEAVE REASONS ────────────────────────────────────────────────────────────
// HR/SUPER_ADMIN managed. Seeded with defaults per leave type.

model LeaveReason {
  id          String    @id @default(cuid())
  leaveKind   LeaveKind
  label       String
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([leaveKind, isActive])
}

// ─── PUBLIC HOLIDAYS ──────────────────────────────────────────────────────────

model PublicHoliday {
  id              String   @id @default(cuid())
  date            DateTime
  name            String
  description     String?
  greetingMessage String?  // sent via email on the day (cron)
  year            Int      // extracted from date for easy filtering
  greetingSent    Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([date])
  @@index([year])
}

// ─── LEAVE ENTITLEMENT ────────────────────────────────────────────────────────
// Balance per employee per leave kind per calendar year (Jan–Dec)

model LeaveEntitlement {
  id              String    @id @default(cuid())
  employeeId      String
  employee        Employee  @relation("EmployeeLeaveEntitlements", fields: [employeeId], references: [id], onDelete: Cascade)
  leaveKind       LeaveKind
  year            Int       // calendar year e.g. 2026

  totalDays       Decimal   @db.Decimal(5, 2)   // granted (pro-rata on join)
  usedDays        Decimal   @default(0) @db.Decimal(5, 2)
  pendingDays     Decimal   @default(0) @db.Decimal(5, 2)  // applied but not yet approved
  lopDays         Decimal   @default(0) @db.Decimal(5, 2)  // auto-LOP days
  carryForward    Decimal   @default(0) @db.Decimal(5, 2)  // brought from previous year (planned only)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([employeeId, leaveKind, year])
  @@index([employeeId, year])
}

// ─── LEAVE APPLICATION ────────────────────────────────────────────────────────
// New model — old LeaveApplication left untouched

model LvApplication {
  id              String      @id @default(cuid())
  employeeId      String
  employee        Employee    @relation("EmployeeLeaveApplications", fields: [employeeId], references: [id], onDelete: Cascade)

  leaveKind       LeaveKind
  startDate       DateTime
  endDate         DateTime
  totalDays       Decimal     @db.Decimal(5, 2)  // computed, excludes weekends + holidays

  isHalfDay       Boolean     @default(false)
  halfDaySlot     HalfDaySlot?  // only when isHalfDay = true

  reasonId        String?     // from LeaveReason
  reasonLabel     String      // stored as text (in case reason deleted later)
  customReason    String?     // free text when "Other" selected
  isBackdated     Boolean     @default(false)

  status          LeaveStatus @default(PENDING)
  isLop           Boolean     @default(false)
  lopDays         Decimal     @default(0) @db.Decimal(5, 2)

  approvedById    String?
  approvedByName  String?
  approvedAt      DateTime?
  declineReason   String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  cancellationRequests LvCancellationRequest[]

  @@index([employeeId, status])
  @@index([employeeId, leaveKind])
  @@index([startDate, endDate])
}

// ─── LEAVE CANCELLATION REQUEST ───────────────────────────────────────────────

model LvCancellationRequest {
  id                String             @id @default(cuid())
  applicationId     String
  application       LvApplication      @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  requestedById     String             // employee or HR/admin
  requestedByName   String
  requestedByRole   String             // EMPLOYEE / HR / SUPER_ADMIN

  type              String             @default("FULL")  // FULL or PARTIAL
  newEndDate        DateTime?          // for partial cancellation (HR/admin only)
  daysToRestore     Decimal            @db.Decimal(5, 2)

  reason            String?
  status            CancellationStatus @default(PENDING)

  respondedById     String?
  respondedByName   String?
  respondedAt       DateTime?
  declineReason     String?

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([applicationId])
  @@index([status])
}

// ─── LEAVE BALANCE SNAPSHOT ───────────────────────────────────────────────────
// Taken on every payroll run. Month-on-month history.

model LeaveBalanceSnapshot {
  id              String    @id @default(cuid())
  employeeId      String
  employee        Employee  @relation("EmployeeLeaveSnapshots", fields: [employeeId], references: [id], onDelete: Cascade)
  payrollCycleId  String    // links to PayrollCycle
  snapshotMonth   String    // e.g. "2026-03"
  year            Int       // leave year

  sickTotal       Decimal   @db.Decimal(5, 2)
  sickUsed        Decimal   @db.Decimal(5, 2)
  sickPending     Decimal   @db.Decimal(5, 2)
  sickBalance     Decimal   @db.Decimal(5, 2)

  casualTotal     Decimal   @db.Decimal(5, 2)
  casualUsed      Decimal   @db.Decimal(5, 2)
  casualPending   Decimal   @db.Decimal(5, 2)
  casualBalance   Decimal   @db.Decimal(5, 2)

  plannedTotal    Decimal   @db.Decimal(5, 2)
  plannedUsed     Decimal   @db.Decimal(5, 2)
  plannedPending  Decimal   @db.Decimal(5, 2)
  plannedBalance  Decimal   @db.Decimal(5, 2)
  plannedCarry    Decimal   @db.Decimal(5, 2)

  createdAt       DateTime  @default(now())

  @@unique([employeeId, snapshotMonth])
  @@index([employeeId])
  @@index([payrollCycleId])
}

// ─── LEAVE ROLLOVER HISTORY ───────────────────────────────────────────────────

model LeaveRolloverHistory {
  id              String   @id @default(cuid())
  fromYear        Int      // e.g. 2025
  toYear          Int      // e.g. 2026
  triggeredById   String
  triggeredByName String
  triggeredAt     DateTime @default(now())
  employeeCount   Int
  summary         Json     // array of { employeeId, name, plannedCarried, newPlannedTotal }

  @@index([fromYear])
}

// ─── COMPANY POLICY ──────────────────────────────────────────────────────────

model CompanyPolicy {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
}

// ─── EXIT CLEARANCE ──────────────────────────────────────────────────────────

model ExitClearance {
  id                String   @id @default(cuid())
  employeeId        String   @unique
  employee          Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  itClearance       Boolean  @default(false)
  itClearedAt       DateTime?
  itClearedBy       String?
  itClearedByName   String?

  assetReturned     Boolean  @default(false)
  assetReturnedAt   DateTime?
  assetReturnedBy   String?
  assetReturnedByName String?

  financeClearance  Boolean  @default(false)
  financeClearedAt  DateTime?
  financeClearedBy  String?
  financeClearedByName String?

  managerClearance  Boolean  @default(false)
  managerClearedAt  DateTime?
  managerClearedBy  String?
  managerClearedByName String?

  ffUnlocked        Boolean  @default(false)
  ffUnlockedAt      DateTime?
  ffUnlockedBy      String?
  ffUnlockedByName  String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ─── EXIT INTERVIEW ──────────────────────────────────────────────────────────

model ExitInterview {
  id              String   @id @default(cuid())
  employeeId      String   @unique
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  isDone          Boolean  @default(false)
  interviewDate   DateTime?
  conductedBy     String?
  conductedByName String?
  notes           String?  @db.Text

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── RESIGNATION HISTORY ─────────────────────────────────────────────────────

model ResignationHistory {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  action          String
  performedById   String
  performedByName String
  performedByRole String
  notes           String?  @db.Text

  createdAt       DateTime @default(now())

  @@index([employeeId])
}

// ─── CRON LOG ─────────────────────────────────────────────────────────────────

model CronLog {
  id          String   @id @default(cuid())
  jobName     String
  triggeredBy String   @default("cron") // "cron" | "manual"
  status      String   // "running" | "success" | "failed" | "partial"
  startedAt   DateTime @default(now())
  completedAt DateTime?
  durationMs  Int?
  message     String?  @db.Text
  errorMessage String? @db.Text
  meta        Json?    // job-specific counts (e.g. { employees: 25, errors: 0 })

  @@index([jobName])
  @@index([startedAt])
}
