# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/csharptek_payroll"

# ─── SERVER ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── MICROSOFT ENTRA ID ──────────────────────────────────────────────────────
# From Azure Portal → App Registrations → CSharpTek Payroll
AZURE_TENANT_ID=PLACEHOLDER
AZURE_CLIENT_ID=PLACEHOLDER
AZURE_CLIENT_SECRET=PLACEHOLDER

# ─── AZURE BLOB STORAGE (Payslip PDF Storage) ────────────────────────────────
# From Azure Portal → Storage Accounts → your account → Access Keys → Connection string
AZURE_STORAGE_CONNECTION_STRING=PLACEHOLDER
# Container name — leave as "payslips" unless you want a different name
AZURE_STORAGE_CONTAINER=payslips

# ─── RESEND (EMAIL) ──────────────────────────────────────────────────────────
# From resend.com → API Keys
RESEND_API_KEY=PLACEHOLDER
# Must be a verified domain in Resend
EMAIL_FROM=payroll@csharptek.com

# ─── CRON ────────────────────────────────────────────────────────────────────
# Any random string — must match x-cron-secret header in Railway Cron commands
CRON_SECRET=PLACEHOLDER
# Receives payroll run success/failure notifications
HR_ALERT_EMAIL=hr@csharptek.com

# ─── DEV MODE ────────────────────────────────────────────────────────────────
# true  = role selector login (no Entra ID needed for local dev)
# false = real Microsoft SSO (production)
DEV_AUTH_BYPASS=true

# ─── PDF GENERATION ──────────────────────────────────────────────────────────
# true  = real Puppeteer PDF (set this in Railway)
# false = HTML stub (local development only)
PUPPETEER_ENABLED=false
