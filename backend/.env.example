# ─── DATABASE ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/csharptek_payroll"

# ─── SERVER ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── MICROSOFT ENTRA ID ─────────────────────────────────────────────────────
# Fill these in when you have the App Registration ready
AZURE_TENANT_ID=PLACEHOLDER
AZURE_CLIENT_ID=PLACEHOLDER
AZURE_CLIENT_SECRET=PLACEHOLDER

# ─── CLOUDFLARE R2 ──────────────────────────────────────────────────────────
R2_ACCOUNT_ID=PLACEHOLDER
R2_ACCESS_KEY_ID=PLACEHOLDER
R2_SECRET_ACCESS_KEY=PLACEHOLDER
R2_BUCKET_NAME=csharptek-payslips
R2_PUBLIC_URL=PLACEHOLDER

# ─── RESEND (EMAIL) ─────────────────────────────────────────────────────────
RESEND_API_KEY=PLACEHOLDER
EMAIL_FROM=payroll@csharptek.com

# ─── DEV MODE ───────────────────────────────────────────────────────────────
# Set to true to enable the dev login bypass (role selector)
DEV_AUTH_BYPASS=true

# ─── CRON ────────────────────────────────────────────────────────────────────
# Secret header Railway sends when triggering cron endpoints
CRON_SECRET=PLACEHOLDER
# HR email for payroll run notifications
HR_ALERT_EMAIL=hr@csharptek.com
